{
  "version": 2,
  "builds": [
    { "src": "api/products.js", "use": "@vercel/node" },
    { "src": "api/orders.js",   "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/products", "dest": "/api/products.js" },
    { "src": "/api/orders",   "dest": "/api/orders.js"   },
    { "src": "/(.*)",          "dest": "/$1"              }
  ]
}
